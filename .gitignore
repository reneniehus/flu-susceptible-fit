# ---- R session / IDE ----
.Rproj.user/
.Rhistory
.RData
.RDataTmp
.Ruserdata
*.PROFILE

# ---- renv (keep the lockfile + settings, ignore the local library/cache) ----
renv/library/
renv/local/
renv/cellar/
renv/lib/
renv/python/
renv/staging/

# ---- build artifacts: cached data lists & derived tables (regenerated by load_data) ----
output/*.Rdata
output/*.csv
output/*.rds
output/*.png
!output/.gitkeep

# ---- generated reports & knit artifacts ----
code/03_report/*.html
code/03_report/figure/
documentation/*.html
figure/

# ---- model output / large files written outside the repo ----
output/*-forecast-hub/
packrat/lib*/
